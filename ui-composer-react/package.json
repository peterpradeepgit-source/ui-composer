{
  "name": "ui-composer-react",
  "version": "2.1.0",
  "description": "A React visual UI composer with drag-and-drop layout editing, built-in components, and runtime component registration.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "keywords": [
    "react",
    "ui-builder",
    "drag-and-drop",
    "visual-editor",
    "component-composer"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/clean-dist.mjs && vite build && tsc -p tsconfig.build.json && node scripts/fix-dts-extensions.mjs",
    "build:demo": "vite build --mode demo",
    "lint": "eslint .",
    "test": "node --test --experimental-strip-types --experimental-specifier-resolution=node src/core/*.test.ts src/builder/*.test.ts src/demo/*.test.ts src/export/*.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "nanoid": "^5.1.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
